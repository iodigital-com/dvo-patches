+<?php
+
+/**
+ * @file
+ * Install, update and uninstall functions for the dvg_siteimprove module.
+ */
+
+/**
+ * Implements hook_install().
+ */
+
+/**
+ * Update Scribit ID.
+ */
+function scribit_pro_update_8001() {
+  $config_factory = \Drupal::configFactory();
+  $config = $config_factory->getEditable('scribit_pro.settings');
+  $config->set('scribit_id', $config->get('user_id'))->save();
+}
