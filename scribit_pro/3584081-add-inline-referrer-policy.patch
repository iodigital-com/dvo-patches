+
+/**
+ * Handles the "callback" route.
+ */
+class Callback extends ControllerBase {
+
+  use MessengerTrait;
+
+  /**
+   * Scribit.pro is calls this callback after the video is processed.
+   *
+   * @param \Symfony\Component\HttpFoundation\Request $request
