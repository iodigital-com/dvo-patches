@@ -322,17 +364,58 @@ class ConfigurableViewsExposedFilterBlock extends CoreViewsExposedFilterBlock {
   }
 
   /**
-   * Hides a given element.
-   *
-   * Current form field values are lost by using the "#access" property, so
-   * form fields are only visually hidden.
+   * Hides or removes a given element per configured removal strategy.
    *
    * @param array $element
-   *   The form element to be hide.
+   *   The form element to hide or remove.
+   */
+  protected function hideElement(array &$element) {
+    switch ($this->configuration['removal_strategy']) {
+      case 'hide':
+        $element['#prefix'] = '<div class="hidden-exposed-filter">';
+        $element['#suffix'] = '</div>';
+        break;
+
+      case 'remove':
+        $element['#access'] = FALSE;
+        break;
+
+    }
+  }
+
+  /**
+   * Sets a given attribute to all form input elements in the build array.
+   *
+   * @param array $build
+   *   The current build array.
+   * @param string $attribute
+   *   The attribute name.
+   * @param string $value
+   *   The attribute value.
    */
-  protected function hideElement(&$element) {
-    $element['#prefix'] = '<div class="hidden-exposed-filter">';
-    $element['#suffix'] = '</div>';
+  protected function setFormAttribute(array &$build, string $attribute, string $value) {
+    $inputTypes = [
+      'textfield',
+      'textarea',
+      'select',
+      'checkbox',
+      'radios',
+      'radio',
+      'email',
+      'number',
+      'tel',
+      'url',
+      'date',
+      'datetime',
+      'password',
+    ];
+    foreach (Element::children($build) as $child_name) {
+      if (isset($build[$child_name]['#type']) && in_array($build[$child_name]['#type'], $inputTypes)) {
+        $build[$child_name]['#attributes'][$attribute] = $value;
+      }
+      // Recurse into child elements.
+      $this->setFormAttribute($build[$child_name], $attribute, $value);
+    }
   }
 
 }
