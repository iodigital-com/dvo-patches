diff --git a/js/configurable_views_filter_block.js b/js/configurable_views_filter_block.js
new file mode 100644
index 0000000..cdec139
--- /dev/null
+++ b/js/configurable_views_filter_block.js
@@ -0,0 +1,88 @@
+(function ($, Drupal, once) {
+  Drupal.behaviors.configurableViewsFilterBlockAutoSubmit = {
+    attach: function (context) {
+      var elements = once(
+        'cvfb-auto-submit',
+        '[data-cvfb-external-form-id]',
+        context
+      );
+      $(elements).each(function () {
+        var $element = $(this);
+        var externalFormId = $element.data('cvfb-external-form-id');
+        var $externalForm = $('#' + externalFormId);
+
+        if ($externalForm.length) {
+          // Add data-bef-auto-submit-exclude to prevent BEF's own auto-submit.
+          $element.attr('data-bef-auto-submit-exclude', '');
+
+          $element.closest('.js-facets-widget').on('facets_filter.cvfb', function (event) {
+            event.preventDefault();
+            event.stopPropagation();
+            event.stopImmediatePropagation();
+          });
+
+          $element.on('facets_filter.cvfb', function (event) {
+            event.preventDefault();
+            event.stopPropagation();
+            event.stopImmediatePropagation();
+          });
+
+          $element.on('change', function (event) {
+            // Stop other handlers (like BEF's auto-submit) from running.
+            event.stopImmediatePropagation();
+            event.stopPropagation();
+
+            // Click the submit button in the external form.
+            var $submit = $externalForm.find('[data-bef-auto-submit-click]');
+            if ($submit.length) {
+              // Trigger a real click so that Drupal AJAX can catch it.
+              $submit[0].click();
+            }
+            else {
+              // Fallback to finding any submit button if no BEF-specific one.
+              $submit = $externalForm.find('input[type="submit"], button[type="submit"]').first();
+              if ($submit.length) {
+                $submit[0].click();
+              }
+              else {
+                $externalForm.submit();
+              }
+            }
+          });
+
+          // Also handle keyup for textfields if BEF auto-submit is enabled.
+          if ($element.is(':text:not(.hasDatepicker), textarea')) {
+            var $form = $element.closest('form');
+            var delay = $form.data('bef-auto-submit-delay') || 500;
+            $element.on('keyup', Drupal.debounce(function (event) {
+              // Stop other handlers (like BEF's auto-submit) from running.
+              event.stopImmediatePropagation();
+              event.stopPropagation();
+
+              var ignored = [
+                16, 17, 18, 20, 33, 34, 35, 36, 37, 38, 39, 40, 9, 13, 27
+              ];
+              if ($.inArray(event.keyCode, ignored) === -1) {
+                var $submit = $externalForm.find(
+                  '[data-bef-auto-submit-click]'
+                );
+                if ($submit.length) {
+                  $submit[0].click();
+                }
+                else {
+                  $submit = $externalForm.find('input[type="submit"], button[type="submit"]').first();
+                  if ($submit.length) {
+                    $submit[0].click();
+                  }
+                  else {
+                    $externalForm.submit();
+                  }
+                }
+              }
+            }, delay));
+          }
+        }
+      });
+    }
+  };
+})(jQuery, Drupal, once);
