new file mode 100644
index 0000000000000000000000000000000000000000..ed334799c5ab9db810e215a62f922094aaab1cc0
--- /dev/null
+++ b/src/Event/ShouldTranslateEvent.php
@@ -0,0 +1,68 @@
+<?php
+
+namespace Drupal\inline_entity_form\Event;
+
+use Drupal\Component\EventDispatcher\Event;
+use Drupal\Core\Entity\ContentEntityInterface;
+use Drupal\Core\Form\FormStateInterface;
+
+/**
+ * Event that is fired before an entity is translated.
+ */
+class ShouldTranslateEvent extends Event {
+
+  /**
+   * Creates a new instance of ShouldTranslateEvent.
+   *
+   * @param bool $shouldTranslate
+   *   Whether the entity should be translated.
+   * @param \Drupal\Core\Form\FormStateInterface $formState
+   *   The form state.
+   * @param string $formLangcode
+   *   The parent form langcode.
+   * @param \Drupal\Core\Entity\ContentEntityInterface $entity
+   *   The inline entity that will be translated.
+   */
+  public function __construct(
+    private bool $shouldTranslate,
+    private readonly FormStateInterface $formState,
+    private string $formLangcode,
+    private readonly ContentEntityInterface $entity,
+  ) {}
+
+  /**
+   * Get the current value of shouldTranslate.
+   */
+  public function getShouldTranslate(): bool {
+    return $this->shouldTranslate;
+  }
+
+  /**
+   * Update the current value of shouldTranslate.
+   */
+  public function setShouldTranslate(bool $shouldTranslate): void {
+    $this->shouldTranslate = $shouldTranslate;
+  }
+
+  /**
+   * Get the parent form langcode.
+   */
+  public function getFormLangcode(): string {
+    return $this->formLangcode;
+  }
+
+  /**
+   * Get the inline entity.
+   */
+  public function getEntity(): ContentEntityInterface {
+    return $this->entity;
+  }
+
+  /**
+   * Get the parent form state.
+   */
+  public function getFormState(): FormStateInterface {
+    return $this->formState;
+  }
+
+}
