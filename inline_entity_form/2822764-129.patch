+        foreach ($entity_group as $entity) {
+          $handler = InlineEntityForm::getInlineFormHandler($entity->getEntityTypeId());
+          $referenceUpgrader->upgradeEntityReferences($entity);
+          $handler->save($entity);
+          $referenceUpgrader->registerEntity($entity);
+        }
+      }
+    }
+  }
+
 }
