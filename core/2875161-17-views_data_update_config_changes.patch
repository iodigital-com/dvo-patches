@@ -0,0 +1,21 @@
+<?php
+
+/**
+ * @file
+ * Contains main module functionality.
+ */
+
+use Drupal\Core\Entity\EntityTypeInterface;
+use Drupal\Core\Field\BaseFieldDefinition;
+
+/**
+ * Implements hook_entity_base_field_info().
+ */
+function views_test_optional_field_entity_base_field_info(EntityTypeInterface $entity_type) {
+  if ($entity_type->id() == 'node'
+    && \Drupal::state()->get('views_entity_test.enable_optional_field')) {
+    $definitions['test_optional_field'] = BaseFieldDefinition::create('views_data_optional_field')
+      ->setLabel(t('Test optional_field'));
+    return $definitions;
+  }
+}
