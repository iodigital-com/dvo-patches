diff --git a/core/modules/views/tests/modules/views_test_optional_field/src/Plugin/Field/FieldType/ViewsDataOptionalField.php b/core/modules/views/tests/modules/views_test_optional_field/src/Plugin/Field/FieldType/ViewsDataOptionalField.php
