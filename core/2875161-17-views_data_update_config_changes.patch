     'language',
     'node',
     'user',
+    'views_data_optional_field_test',
   ];
 
   /**
@@ -382,4 +383,43 @@ public function testEntityFieldFilter() {
     $view->destroy();
   }
 
+  /**
+   * Unit testing the views data response to changes.
+   *
+   * We check views data ability to update with config changes.
+   */
+  public function testUpdatedViewsData() {
+    $views_data = $this->container->get('views.views_data');
+
+    NodeType::create(['type' => 'page'])->save();
+
+    FieldStorageConfig::create([
+      'field_name' => 'field_string',
+      'entity_type' => 'node',
+      'type' => 'string',
+    ])->save();
+
+    $unrelated_field = FieldConfig::create([
+      'field_name' => 'field_string',
+      'entity_type' => 'node',
+      'bundle' => 'page',
+      'label' => 'First test field label',
+    ]);
+    $unrelated_field->save();
+
+    // Build the static cache, for example during routes rebuild
+    // after module enabling as part of config sync.
+    $views_data->getAll();
+
+    // Enable the optional field, is often managed via config.
+    \Drupal::state()->set('views_entity_test.enable_optional_field', TRUE);
+
+    // Updating field config clears entity field manager static cache
+    // and simulate changes during a config sync.
+    $unrelated_field->save();
+
+    $new_data = $views_data->get('node_field_data');
+    $this->assertTrue(isset($new_data['test_optional_field']), 'Optional base field is not found.');
+  }
+
 }
