@@ -0,0 +1,55 @@
+<?php
+
+namespace Drupal\views_test_optional_field\Plugin\Field\FieldType;
+
+use Drupal\Core\Field\FieldItemBase;
+use Drupal\Core\Field\FieldStorageDefinitionInterface;
+use Drupal\Core\StringTranslation\TranslatableMarkup;
+use Drupal\Core\TypedData\MapDataDefinition;
+
+/**
+ * Plugin implementation of the 'views_data_optional_field' field type.
+ *
+ * @FieldType(
+ *   id = "views_data_optional_field",
+ *   label = @Translation("Views data optional field"),
+ *   no_ui = TRUE
+ * )
+ */
+class ViewsDataOptionalField extends FieldItemBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  public static function defaultStorageSettings() {
+    return [
+      'views_data_optional_field' => [],
+    ] + parent::defaultStorageSettings();
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public static function propertyDefinitions(FieldStorageDefinitionInterface $field_definition) {
+    $properties['value'] = MapDataDefinition::create()
+      ->setLabel(new TranslatableMarkup('Value'));
+
+    return $properties;
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public static function schema(FieldStorageDefinitionInterface $field_definition) {
+    $schema = [
+      'columns' => [
+        'value' => [
+          'type' => 'int',
+        ],
+      ],
+    ];
+
+    return $schema;
+  }
+
+}
